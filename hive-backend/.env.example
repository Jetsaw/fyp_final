# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=REPLACE_ME

DEEPSEEK_BASE_URL=REPLACE_ME
DEEPSEEK_MODEL=REPLACE_ME

# LLM Control (set to true to enable LLM generation, false for RAG-only mode)
USE_LLM=REPLACE_ME

DATA_DIR=REPLACE_ME
GLOBAL_DOCS_DIR=REPLACE_ME
GLOBAL_INDEX_DIR=REPLACE_ME
SQLITE_PATH=REPLACE_ME

# since nginx will serve frontend and proxy /api on port 8080
FRONTEND_ORIGIN=REPLACE_ME

TOP_K=REPLACE_ME
MAX_CONTEXT_CHARS=REPLACE_ME
MIN_SCORE=REPLACE_ME
HISTORY_LIMIT=REPLACE_ME

# Voice Settings
WHISPER_MODEL_SIZE=REPLACE_ME
VOICE_PROVIDER=REPLACE_ME
