USE_LLM=false
DEEPSEEK_API_KEY=disabled
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

FRONTEND_ORIGIN=https://hive.yourdomain.com

DATA_DIR=./data
KB_DIR=./data/kb
GLOBAL_DOCS_DIR=./data/global_docs
GLOBAL_INDEX_DIR=./data/indexes/global
SQLITE_PATH=./data/hive.db

TOP_K=4
MAX_CONTEXT_CHARS=12000
MIN_SCORE=0.25
HYBRID_SEARCH_ENABLED=true
HYBRID_DENSE_TOP_K=30
HYBRID_BM25_TOP_K=30
HYBRID_RRF_K=60
RERANKING_ENABLED=true
HISTORY_LIMIT=8

VOICE_PROVIDER=browser

