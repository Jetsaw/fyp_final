:8080 {
    root * /Users/YOUR_MAC_USER/hive/frontend/dist
    encode zstd gzip

    handle /ask* {
        reverse_proxy 127.0.0.1:8000
    }

    handle /api* {
        reverse_proxy 127.0.0.1:8000
    }

    handle /health* {
        reverse_proxy 127.0.0.1:8000
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}

